<Window x:Class="PinBoard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:PinBoard.ViewModels"
        xmlns:ctrl="clr-namespace:PinBoard.Controls"
        xmlns:local="clr-namespace:PinBoard"
        mc:Ignorable="d"
        Title="PinBoard"
        Height="760" Width="1180"
        MinHeight="480" MinWidth="760"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Color swatch button used in the create-preset popup -->
        <ControlTemplate x:Key="SwatchButtonTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="5"
                    BorderBrush="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}" />
        </ControlTemplate>

        <!-- "+" custom-color swatch -->
        <ControlTemplate x:Key="PlusSwatchTemplate" TargetType="Button">
            <Border Background="Transparent" CornerRadius="5"
                    BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="1">
                <TextBlock Text="+" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}" />
            </Border>
        </ControlTemplate>

        <!-- Labeled preview button used for theme chips in Settings -->
        <ControlTemplate x:Key="PreviewButtonTemplate" TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
            </Border>
        </ControlTemplate>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <!-- Outer frame: rounded, dark chrome -->
    <Border Background="{DynamicResource ChromeBrush}"
            CornerRadius="10"
            BorderBrush="{DynamicResource ChromeBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />   <!-- titlebar -->
                <RowDefinition Height="*" />    <!-- sidebar + board -->
                <RowDefinition Height="44" />   <!-- bottom bar -->
            </Grid.RowDefinitions>

            <!-- ============================================================
                 TITLEBAR
                 ============================================================ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource ChromeBrush}"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
                <Grid>
                    <!-- Traffic lights -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="CloseDot" Style="{x:Null}" Width="13" Height="13" Margin="0,0,8,0"
                                Cursor="Hand" Click="Close_Click" ToolTip="Close">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="{StaticResource TrafficCloseBrush}" />
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="13" Height="13" Margin="0,0,8,0" Cursor="Hand"
                                Click="Minimize_Click" ToolTip="Minimize">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="{StaticResource TrafficMinBrush}" />
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Width="13" Height="13" Cursor="Hand"
                                Click="Maximize_Click" ToolTip="Maximize">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Ellipse Fill="{StaticResource TrafficMaxBrush}" />
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Centered board filename -->
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}">
                        <Run Text="{Binding Board.Name, Mode=OneWay}" />
                        <Run Text=" — PinBoard" Foreground="{DynamicResource TextFaintBrush}" />
                    </TextBlock>
                </Grid>
            </Border>

            <!-- ============================================================
                 MAIN AREA: sidebar | board
                 ============================================================ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <Border Grid.Column="0"
                        Background="{DynamicResource ChromeBrush}"
                        BorderBrush="{DynamicResource ChromeBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="True">
                        <!-- Bottom-anchored: settings + board switcher -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
                            <Border Height="1" Margin="8,4" Background="{DynamicResource ChromeBorderBrush}" />
                            <!-- Save -->
                            <Button Style="{StaticResource SidebarButton}" Content="&#xE74E;"
                                    HorizontalAlignment="Center" ToolTip="Save (Ctrl+S)"
                                    Click="Save_Click" />
                            <!-- Board switcher: opens the source folder -->
                            <Button Style="{StaticResource SidebarButton}" Content="&#xE8A9;"
                                    HorizontalAlignment="Center" ToolTip="Open boards folder"
                                    Click="BoardSwitcher_Click" />
                            <!-- Settings (gear) -->
                            <Button Style="{StaticResource SidebarButton}" Content="&#xE713;"
                                    HorizontalAlignment="Center" ToolTip="Settings"
                                    Click="Settings_Click" />
                        </StackPanel>

                        <!-- Top tool stack -->
                        <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                            <!-- Select / pointer -->
                            <Button Style="{StaticResource SidebarButton}" Content="&#xE7C9;"
                                    HorizontalAlignment="Center" ToolTip="Select"
                                    Command="{Binding SelectToolCommand}" CommandParameter="Select"
                                    Background="{Binding ActiveTool, Converter={StaticResource EnumToActiveBrush}, ConverterParameter=Select}" />
                            <!-- Sticky note (add new) -->
                            <Button Style="{StaticResource SidebarButton}" Content="&#xE70B;"
                                    HorizontalAlignment="Center" ToolTip="Add note"
                                    Command="{Binding SelectToolCommand}" CommandParameter="AddNote"
                                    Background="{Binding ActiveTool, Converter={StaticResource EnumToActiveBrush}, ConverterParameter=AddNote}" />
                            <!-- Rope / connection -->
                            <Button Style="{StaticResource SidebarButton}" Content="&#xE71B;"
                                    HorizontalAlignment="Center" ToolTip="Rope"
                                    Command="{Binding SelectToolCommand}" CommandParameter="Rope"
                                    Background="{Binding ActiveTool, Converter={StaticResource EnumToActiveBrush}, ConverterParameter=Rope}" />
                            <!-- Image clip -->
                            <Button Style="{StaticResource SidebarButton}" Content="&#xEB9F;"
                                    HorizontalAlignment="Center" ToolTip="Image clip"
                                    Command="{Binding SelectToolCommand}" CommandParameter="ImageClip"
                                    Background="{Binding ActiveTool, Converter={StaticResource EnumToActiveBrush}, ConverterParameter=ImageClip}" />
                            <!-- Document clip -->
                            <Button Style="{StaticResource SidebarButton}" Content="&#xE7C3;"
                                    HorizontalAlignment="Center" ToolTip="Document clip"
                                    Command="{Binding SelectToolCommand}" CommandParameter="DocumentClip"
                                    Background="{Binding ActiveTool, Converter={StaticResource EnumToActiveBrush}, ConverterParameter=DocumentClip}" />

                            <Border Height="1" Margin="8,6" Background="{DynamicResource ChromeBorderBrush}" />

                            <!-- Pan / hand -->
                            <Button Style="{StaticResource SidebarButton}" Content="&#xE7C2;"
                                    HorizontalAlignment="Center" ToolTip="Pan"
                                    Command="{Binding SelectToolCommand}" CommandParameter="Pan"
                                    Background="{Binding ActiveTool, Converter={StaticResource EnumToActiveBrush}, ConverterParameter=Pan}" />
                            <!-- Zoom in -->
                            <Button Style="{StaticResource SidebarButton}" Content="&#xE8A3;"
                                    HorizontalAlignment="Center" ToolTip="Zoom in"
                                    Click="ZoomIn_Click" />
                            <!-- Zoom out -->
                            <Button Style="{StaticResource SidebarButton}" Content="&#xE71F;"
                                    HorizontalAlignment="Center" ToolTip="Zoom out"
                                    Click="ZoomOut_Click" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- BOARD SURFACE: no scrollbars; mouse pan + wheel zoom.
                     The backdrop fills the viewport so the board feels infinite;
                     the WorldCanvas carries the pan/zoom transform and hosts items. -->
                <Border Grid.Column="1" x:Name="BoardHost"
                        ClipToBounds="True"
                        Background="{DynamicResource BoardBaseColorBrush}"
                        Focusable="True"
                        AllowDrop="True"
                        DragOver="BoardHost_DragOver"
                        Drop="BoardHost_Drop"
                        MouseWheel="BoardHost_MouseWheel"
                        MouseDown="BoardHost_MouseDown"
                        MouseMove="BoardHost_MouseMove"
                        MouseUp="BoardHost_MouseUp">
                    <Canvas x:Name="WorldCanvas"
                            Width="10000" Height="10000"
                            Background="{DynamicResource BoardBaseColorBrush}"
                            RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="WorldScale" ScaleX="1" ScaleY="1" />
                                <TranslateTransform x:Name="WorldTranslate" X="0" Y="0" />
                            </TransformGroup>
                        </Canvas.RenderTransform>

                        <!-- Ropes drawn BEHIND notes/clips -->
                        <ItemsControl x:Name="RopesBackHost" ItemsSource="{Binding Board.RopesBackLayer}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ctrl:RopeControl />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Clips (images / documents) -->
                        <ItemsControl x:Name="ClipsHost" ItemsSource="{Binding Board.Clips}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ctrl:ClipControl />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Notes -->
                        <ItemsControl x:Name="NotesHost" ItemsSource="{Binding Board.Notes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    <Setter Property="Panel.ZIndex" Value="{Binding ZIndex}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ctrl:NoteControl />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Ropes drawn IN FRONT of notes/clips -->
                        <ItemsControl x:Name="RopesFrontHost" ItemsSource="{Binding Board.RopesFrontLayer}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ctrl:RopeControl />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Live preview while dragging a new rope -->
                        <Path x:Name="RopePreview" StrokeThickness="2.6" Opacity="0.8"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              IsHitTestVisible="False" Visibility="Collapsed" />
                    </Canvas>
                </Border>
            </Grid>

            <!-- ============================================================
                 BOTTOM BAR
                 ============================================================ -->
            <Border Grid.Row="2"
                    Background="{DynamicResource ChromeAltBrush}"
                    CornerRadius="0,0,10,10"
                    BorderBrush="{DynamicResource ChromeBorderBrush}"
                    BorderThickness="0,1,0,0">
                <!-- Rope preset "strings" -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Left" Margin="14,0">
                        <ItemsControl ItemsSource="{Binding Board.RopePresets}" VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="3,0" Padding="8,3" CornerRadius="11"
                                            Cursor="Hand"
                                            Background="{Binding IsActive, Converter={StaticResource BoolToBrush}, ConverterParameter=ChromeActiveBrush|}"
                                            MouseLeftButtonDown="RopePreset_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                                     Fill="{Binding ColorBrush}" />
                                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Text="{Binding DisplayName}" />
                                            <Button Margin="6,0,0,0" VerticalAlignment="Center"
                                                    Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                    FontSize="8" Width="14" Height="14" Padding="0"
                                                    Foreground="{DynamicResource TextFaintBrush}"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" ToolTip="Remove preset"
                                                    Click="RemovePreset_Click" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Add preset -->
                        <Button x:Name="AddPresetButton" Margin="4,0,0,0"
                                Width="24" Height="24" Cursor="Hand"
                                Content="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                Foreground="{DynamicResource TextMutedBrush}"
                                ToolTip="New rope type"
                                Click="AddPresetButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChromeHoverBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Create-preset popup -->
                        <Popup x:Name="AddPresetPopup" PlacementTarget="{Binding ElementName=AddPresetButton}"
                               Placement="Top" StaysOpen="False" AllowsTransparency="True"
                               PopupAnimation="Fade" HorizontalOffset="-90" VerticalOffset="-6">
                            <Border Background="{DynamicResource ChromeAltBrush}"
                                    BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="1"
                                    CornerRadius="8" Padding="12" Width="248">
                                <StackPanel>
                                    <TextBlock Text="New rope type" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
                                    <TextBox x:Name="PresetNameInput"
                                             Background="{DynamicResource ChromeBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             CaretBrush="{DynamicResource TextPrimaryBrush}"
                                             BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="1"
                                             Padding="6,4" FontSize="12"
                                             Tag="e.g. linked, confirms…" />
                                    <TextBlock Text="Color" FontSize="10" Margin="0,10,0,5"
                                               Foreground="{DynamicResource TextMutedBrush}" />
                                    <WrapPanel x:Name="ColorSwatchPanel" />
                                    <CheckBox x:Name="DashedToggle" Content="Dashed" Margin="0,10,0,0"
                                              Foreground="{DynamicResource TextMutedBrush}" FontSize="11" />
                                    <Button Content="Add rope type" Margin="0,12,0,0"
                                            Style="{StaticResource AccentButton}" HorizontalAlignment="Right"
                                            Click="CreatePreset_Click" />
                                </StackPanel>
                            </Border>
                        </Popup>
                </StackPanel>
            </Border>

            <!-- ============================================================
                 SETTINGS slide-out overlay
                 ============================================================ -->
            <Border x:Name="SettingsScrim" Grid.Row="1" Background="#66000000"
                    Visibility="Collapsed" MouseLeftButtonDown="SettingsScrim_Click" />

            <Border x:Name="SettingsPanel" Grid.Row="1" Width="344"
                    HorizontalAlignment="Right"
                    Background="{DynamicResource ChromeAltBrush}"
                    BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="SettingsTransform" X="344" />
                </Border.RenderTransform>
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="18,16,12,8">
                        <TextBlock Text="Settings" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        <Button HorizontalAlignment="Right" Width="26" Height="26" Cursor="Hand"
                                Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                Foreground="{DynamicResource TextMutedBrush}" Background="Transparent"
                                BorderThickness="0" Click="CloseSettings_Click" ToolTip="Close" />
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,4,16,18">
                        <StackPanel>
                            <!-- APPEARANCE -->
                            <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,0" />
                            <TextBlock Text="App theme" FontSize="11"
                                       Foreground="{DynamicResource TextFaintBrush}" Margin="0,10,0,6" />
                            <WrapPanel x:Name="AppThemePanel" />
                            <TextBlock Text="Board background" FontSize="11"
                                       Foreground="{DynamicResource TextFaintBrush}" Margin="0,12,0,6" />
                            <WrapPanel x:Name="BoardThemePanel" />
                            <TextBlock Text="Custom background color" FontSize="11"
                                       Foreground="{DynamicResource TextFaintBrush}" Margin="0,12,0,6" />
                            <WrapPanel x:Name="BoardColorPanel" />

                            <!-- ROPES -->
                            <TextBlock Text="ROPES" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,22,0,0" />
                            <DockPanel Margin="0,12,0,4">
                                <TextBlock Text="Sag / curve" FontSize="11"
                                           Foreground="{DynamicResource TextFaintBrush}" />
                                <TextBlock x:Name="SagValue" DockPanel.Dock="Right" FontSize="11"
                                           HorizontalAlignment="Right"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                            </DockPanel>
                            <Slider x:Name="SagSlider" Minimum="0" Maximum="0.45"
                                    ValueChanged="SagSlider_ValueChanged" />
                            <DockPanel Margin="0,12,0,4">
                                <TextBlock Text="Thickness" FontSize="11"
                                           Foreground="{DynamicResource TextFaintBrush}" />
                                <TextBlock x:Name="ThicknessValue" DockPanel.Dock="Right" FontSize="11"
                                           HorizontalAlignment="Right"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                            </DockPanel>
                            <Slider x:Name="ThicknessSlider" Minimum="2" Maximum="12"
                                    ValueChanged="ThicknessSlider_ValueChanged" />
                            <CheckBox x:Name="RopesFrontToggle" Content="New ropes in front of notes"
                                      Margin="0,12,0,0" FontSize="11"
                                      Foreground="{DynamicResource TextMutedBrush}"
                                      Checked="RopesFrontToggle_Changed" Unchecked="RopesFrontToggle_Changed" />

                            <!-- HOTKEYS -->
                            <TextBlock Text="HOTKEYS" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,22,0,4" />
                            <StackPanel x:Name="HotkeyPanel" />

                            <!-- NOTES -->
                            <TextBlock Text="NOTES" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,22,0,0" />
                            <TextBlock Text="Default note color" FontSize="11"
                                       Foreground="{DynamicResource TextFaintBrush}" Margin="0,10,0,6" />
                            <WrapPanel x:Name="NoteColorPanel" />

                            <!-- FILES -->
                            <TextBlock Text="FILES" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}" Margin="0,22,0,0" />
                            <TextBlock Text="Board save folder" FontSize="11"
                                       Foreground="{DynamicResource TextFaintBrush}" Margin="0,10,0,6" />
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Browse" Margin="8,0,0,0"
                                        Style="{StaticResource ChromeButton}" Click="BrowseFolder_Click" />
                                <TextBox x:Name="HomeFolderBox" IsReadOnly="True" VerticalContentAlignment="Center"
                                         Background="{DynamicResource ChromeBrush}"
                                         Foreground="{DynamicResource TextMutedBrush}"
                                         BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="1"
                                         Padding="6,4" FontSize="11" />
                            </DockPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
