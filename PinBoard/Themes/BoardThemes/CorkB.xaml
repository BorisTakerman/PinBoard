<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Flat base tone painted behind the textured surface (no second texture
         to ghost when zooming). -->
    <SolidColorBrush x:Key="BoardBaseColorBrush" Color="#c4a47a" />

    <!-- ============================================================
         Cork B (RECOMMENDED DEFAULT)
         Base #c4a47a with loose, low-opacity diagonal streaks.
         Reads clearly as cork without being noisy.
         Pure vector DrawingBrush — stays crisp at any zoom.
         ============================================================ -->

    <DrawingBrush x:Key="BoardBackgroundBrush"
                  TileMode="Tile"
                  Viewport="0,0,180,180"
                  ViewportUnits="Absolute"
                  Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <!-- Base cork tone -->
                <GeometryDrawing Brush="#c4a47a">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,180,180" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Loose diagonal streaks (down-right), low opacity -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#1a6e4f2a" Thickness="9" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="-40,30"  EndPoint="60,130" />
                            <LineGeometry StartPoint="50,-20"  EndPoint="170,100" />
                            <LineGeometry StartPoint="120,40"  EndPoint="220,140" />
                            <LineGeometry StartPoint="-20,120" EndPoint="80,220" />
                            <LineGeometry StartPoint="90,110"  EndPoint="200,220" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Lighter counter-streaks for grain variation -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#14ffe6c0" Thickness="5" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,70"    EndPoint="90,160" />
                            <LineGeometry StartPoint="70,10"   EndPoint="180,120" />
                            <LineGeometry StartPoint="130,90"  EndPoint="210,170" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

</ResourceDictionary>
