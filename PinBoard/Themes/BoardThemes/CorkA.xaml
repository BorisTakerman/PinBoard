<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Flat base tone painted behind the textured surface (no second texture
         to ghost when zooming). -->
    <SolidColorBrush x:Key="BoardBaseColorBrush" Color="#c9a97a" />

    <!-- ============================================================
         Cork A — flat warm tan #c9a97a, very faint crosshatch
         overlay and barely-there grain. The calmest cork.
         ============================================================ -->

    <DrawingBrush x:Key="BoardBackgroundBrush"
                  TileMode="Tile"
                  Viewport="0,0,40,40"
                  ViewportUnits="Absolute"
                  Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#c9a97a">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,40,40" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Faint crosshatch: one set each direction -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#0e5c3f1a" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0"  EndPoint="40,40" />
                            <LineGeometry StartPoint="40,0" EndPoint="0,40" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Barely-there grain flecks -->
                <GeometryDrawing Brush="#10ffe9c8">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="9,12"  RadiusX="1.1" RadiusY="1.1" />
                            <EllipseGeometry Center="28,7"  RadiusX="0.8" RadiusY="0.8" />
                            <EllipseGeometry Center="33,30" RadiusX="1.0" RadiusY="1.0" />
                            <EllipseGeometry Center="15,32" RadiusX="0.9" RadiusY="0.9" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

</ResourceDictionary>
