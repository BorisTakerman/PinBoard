<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Flat base tone painted behind the textured surface (no second texture
         to ghost when zooming). -->
    <SolidColorBrush x:Key="BoardBaseColorBrush" Color="#1a1b1f" />

    <!-- ============================================================
         Dark — near-black #1a1b1f with a subtle dot-grid overlay
         (~28px spacing). Notes render in muted/tinted dark variants
         on this theme.
         ============================================================ -->

    <DrawingBrush x:Key="BoardBackgroundBrush"
                  TileMode="Tile"
                  Viewport="0,0,28,28"
                  ViewportUnits="Absolute"
                  Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#1a1b1f">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,28,28" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Single dot per tile -> regular 28px grid -->
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush>
                            <GradientStop Color="#2effffff" Offset="0" />
                            <GradientStop Color="#10ffffff" Offset="0.6" />
                            <GradientStop Color="#00ffffff" Offset="1" />
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="14,14" RadiusX="1.6" RadiusY="1.6" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

</ResourceDictionary>
