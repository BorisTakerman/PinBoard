<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Flat base tone painted behind the textured surface (no second texture
         to ghost when zooming). -->
    <SolidColorBrush x:Key="BoardBaseColorBrush" Color="#be9e6e" />

    <!-- ============================================================
         Cork C — base #be9e6e, soft radial "blob" cells mimicking
         natural cork granules. The most organic of the four.
         ============================================================ -->

    <DrawingBrush x:Key="BoardBackgroundBrush"
                  TileMode="Tile"
                  Viewport="0,0,90,90"
                  ViewportUnits="Absolute"
                  Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#be9e6e">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,90,90" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Soft darker cells -->
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush>
                            <GradientStop Color="#22000000" Offset="0" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="20,22" RadiusX="16" RadiusY="13" />
                            <EllipseGeometry Center="64,30" RadiusX="14" RadiusY="17" />
                            <EllipseGeometry Center="38,62" RadiusX="18" RadiusY="14" />
                            <EllipseGeometry Center="78,72" RadiusX="13" RadiusY="13" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Soft lighter cells for granular variation -->
                <GeometryDrawing>
                    <GeometryDrawing.Brush>
                        <RadialGradientBrush>
                            <GradientStop Color="#1cfff0d2" Offset="0" />
                            <GradientStop Color="#00fff0d2" Offset="1" />
                        </RadialGradientBrush>
                    </GeometryDrawing.Brush>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <EllipseGeometry Center="44,18" RadiusX="11" RadiusY="10" />
                            <EllipseGeometry Center="12,56" RadiusX="12" RadiusY="11" />
                            <EllipseGeometry Center="68,52" RadiusX="10" RadiusY="12" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

</ResourceDictionary>
