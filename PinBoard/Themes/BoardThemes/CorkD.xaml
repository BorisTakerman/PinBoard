<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Flat base tone painted behind the textured surface (no second texture
         to ghost when zooming). -->
    <SolidColorBrush x:Key="BoardBaseColorBrush" Color="#d4b48a" />

    <!-- ============================================================
         Cork D — lightest tone #d4b48a, multi-angle line layers.
         The most "obviously cork" of the four.
         ============================================================ -->

    <DrawingBrush x:Key="BoardBackgroundBrush"
                  TileMode="Tile"
                  Viewport="0,0,120,120"
                  ViewportUnits="Absolute"
                  Stretch="None">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#d4b48a">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,120,120" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Layer 1: down-right -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#16704a22" Thickness="3" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="-20,20"  EndPoint="100,140" />
                            <LineGeometry StartPoint="40,-20"  EndPoint="160,100" />
                            <LineGeometry StartPoint="-20,80"  EndPoint="60,160" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Layer 2: down-left -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#12704a22" Thickness="3" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="140,20" EndPoint="20,140" />
                            <LineGeometry StartPoint="80,-20" EndPoint="-40,100" />
                            <LineGeometry StartPoint="140,80" EndPoint="60,160" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>

                <!-- Layer 3: faint near-vertical highlights -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#12fff0d2" Thickness="2" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="30,0"  EndPoint="38,120" />
                            <LineGeometry StartPoint="86,0"  EndPoint="78,120" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

</ResourceDictionary>
