<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <!-- The .NET 8 runtime isn't installed on this machine (only 6 and 10).
         Roll forward so the .NET 8-targeted app runs on the installed .NET 10
         runtime. Remove this if you install the .NET 8 Desktop Runtime. -->
    <RollForward>LatestMajor</RollForward>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>PinBoard.ico</ApplicationIcon>
    <AssemblyName>PinBoard</AssemblyName>
    <RootNamespace>PinBoard</RootNamespace>

    <!-- Release / publish metadata -->
    <Product>PinBoard</Product>
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- Embedded so the window/taskbar icon can reference it at runtime -->
    <Resource Include="PinBoard.ico" />
  </ItemGroup>

</Project>
