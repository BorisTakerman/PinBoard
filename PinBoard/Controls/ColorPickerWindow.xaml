<Window x:Class="PinBoard.Controls.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick a color"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border Margin="10" CornerRadius="12" Padding="16"
            Background="{DynamicResource ChromeAltBrush}"
            BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="5" Direction="270" Opacity="0.5" Color="#000000" />
        </Border.Effect>
        <StackPanel Width="220">
            <Grid Margin="0,0,0,12" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <TextBlock Text="Pick a color" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                <Button HorizontalAlignment="Right" Width="24" Height="24" Cursor="Hand"
                        Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Foreground="{DynamicResource TextMutedBrush}" Background="Transparent"
                        BorderThickness="0" Click="Cancel_Click" />
            </Grid>

            <Canvas x:Name="WheelCanvas" Width="200" Height="200" HorizontalAlignment="Center"
                    MouseLeftButtonDown="Wheel_MouseDown" MouseMove="Wheel_MouseMove"
                    MouseLeftButtonUp="Wheel_MouseUp">
                <Image x:Name="WheelImage" Width="200" Height="200" />
                <Ellipse x:Name="Thumb" Width="14" Height="14" IsHitTestVisible="False"
                         Stroke="White" StrokeThickness="2">
                    <Ellipse.Effect>
                        <DropShadowEffect BlurRadius="3" ShadowDepth="0" Opacity="0.8" Color="#000000" />
                    </Ellipse.Effect>
                </Ellipse>
            </Canvas>

            <TextBlock Text="Brightness" FontSize="10" Margin="0,12,0,2"
                       Foreground="{DynamicResource TextMutedBrush}" />
            <Slider x:Name="ValueSlider" Minimum="0" Maximum="1" Value="1"
                    ValueChanged="ValueSlider_ValueChanged" />

            <DockPanel Margin="0,12,0,0">
                <Border x:Name="PreviewSwatch" DockPanel.Dock="Left" Width="36" Height="30"
                        CornerRadius="5" BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="1" />
                <TextBox x:Name="HexBox" Margin="10,0,0,0" VerticalContentAlignment="Center"
                         Background="{DynamicResource ChromeBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         CaretBrush="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource ChromeBorderBrush}" BorderThickness="1"
                         Padding="6,0" FontSize="12" KeyDown="HexBox_KeyDown" LostFocus="HexBox_Commit" />
            </DockPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Cancel" Style="{StaticResource ChromeButton}" Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button Content="Use color" Style="{StaticResource AccentButton}" Click="Ok_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
