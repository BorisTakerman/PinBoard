<UserControl x:Class="PinBoard.Controls.NoteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="{Binding Width}" Height="{Binding Height}"
             d:DesignWidth="180" d:DesignHeight="180">

    <UserControl.ContextMenu>
        <ContextMenu x:Name="NoteMenu">
            <MenuItem Header="Edit label" Click="EditLabel_Click" />
            <MenuItem x:Name="ColorMenu" Header="Change color" />
            <MenuItem x:Name="PinColorMenu" Header="Change pin color" />
            <Separator />
            <MenuItem Header="Duplicate" Click="Duplicate_Click" />
            <MenuItem Header="Bring to front" Click="BringToFront_Click" />
            <MenuItem Header="Send to back" Click="SendToBack_Click" />
            <Separator />
            <MenuItem Header="Delete" Click="Delete_Click" />
        </ContextMenu>
    </UserControl.ContextMenu>

    <Grid>
        <!-- Note body -->
        <Border x:Name="Body"
                Margin="0,12,0,0"
                CornerRadius="3"
                Background="#F4C969"
                MouseLeftButtonDown="Body_MouseLeftButtonDown"
                MouseMove="Body_MouseMove"
                MouseLeftButtonUp="Body_MouseLeftButtonUp">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="4" Direction="300"
                                  Opacity="0.34" Color="#000000" />
            </Border.Effect>

            <Grid Margin="14,15,14,11">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Category label (tiny uppercase) -->
                <TextBox x:Name="LabelBox" Grid.Row="0"
                         Visibility="Collapsed"
                         Background="Transparent" BorderThickness="0" Padding="0"
                         FontSize="9.5" FontWeight="SemiBold"
                         IsReadOnly="True" IsHitTestVisible="False" Focusable="False"
                         LostKeyboardFocus="LabelBox_LostKeyboardFocus"
                         KeyDown="EditBox_KeyDown"
                         Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Body text -->
                <TextBox x:Name="BodyBox" Grid.Row="1"
                         Margin="0,4,0,0"
                         Background="Transparent" BorderThickness="0" Padding="0"
                         FontSize="13" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         IsReadOnly="True" IsHitTestVisible="False" Focusable="False"
                         LostKeyboardFocus="BodyBox_LostKeyboardFocus"
                         Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Faint rule near the bottom -->
                <Border x:Name="Rule" Grid.Row="2" Height="1" Margin="0,6,0,2"
                        Background="#332B2722" />
            </Grid>
        </Border>

        <!-- Selection ring -->
        <Border x:Name="SelectionRing"
                Margin="-2,10,-2,-2"
                CornerRadius="5"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="2"
                IsHitTestVisible="False"
                Visibility="Collapsed" />

        <!-- Pin at top-center -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Top"
              Width="20" Height="22" IsHitTestVisible="False">
            <Ellipse Width="15" Height="15" Fill="#40000000" Margin="3,4,0,0" />
            <Ellipse x:Name="PinFill" Width="15" Height="15" Fill="#E5604A" Margin="0,1,0,0" />
            <Ellipse Width="5" Height="5" Fill="#80FFFFFF" Margin="-5,-4,0,0" />
        </Grid>

        <!-- Resize grip (bottom-right) -->
        <Border x:Name="ResizeHandle"
                Width="18" Height="18"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNWSE"
                MouseLeftButtonDown="Resize_MouseLeftButtonDown"
                MouseMove="Resize_MouseMove"
                MouseLeftButtonUp="Resize_MouseLeftButtonUp">
            <Path x:Name="GripPath" Stroke="#552B2722" StrokeThickness="1.3" Margin="0,0,3,3"
                  Data="M 14,6 L 6,14 M 14,10 L 10,14" />
        </Border>
    </Grid>
</UserControl>
